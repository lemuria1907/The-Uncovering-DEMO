    "t_andy_chat": {
      "char": "char_andy",
      "title": "和Andy的对话",
      "dialogue": [
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "我们按照琴警官的吩咐，打开了死者的私人储物柜。然后，也拜托真橙、阿祐、美羽打开柜子让我们检查了一下。"
        },
        {
          "s": "player",
          "speaker": "none",
          "t": "有什么奇怪的东西吗？"
        },
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "都是些换洗衣服、杂物、文件、药品之类的。"
        },
        {
          "s": "player",
          "speaker": "none",
          "t": "好，我自己来查看吧。还有，昨天琴警官说有游客在鬼屋丢东西的事情是怎么回事？"
        },
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "哎……其实已经找到了，不是在鬼屋里找到的。鬼屋附近有个小凉亭，游客打电话的时候，手机一响，有坐那儿休息的游客就听见背后草丛里面有声音。"
        },
        {
          "s": "player",
          "speaker": "none",
          "t": "那是几点的事情？"
        },
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "就刚刚，十点多的时候。我们发现之后马上跟游客联系，要了地址邮寄过去。"
        },
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "琴警官说，等你在这里查看完毕之后，可以去临时问讯区域，明淇和美羽应该已经到了。",
          "unlockLoc": [
            "interrogation",
            "office"
          ],
          "unlockTopic": [
            "t_meiyu_self",
            "t_meiyu_relation_dead",
            "t_meiyu_day",
            "t_meiyu_float_accident",
            "t_mingqi_self",
            "t_mingqi_relation_dead",
            "t_mingqi_day",
            "t_shihui_about_mingqi",
            "t_shihui_float_accident"
          ],
          "unlockProfile": [
            "char_meiyu"
          ]
        },
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "哦对了，琴警官让我们调查常威的办公电脑，邮箱什么的。这个东西你可能会感兴趣。",
          "unlockEv": [
            "ev_mingqi_changwei_mail"
          ]
        }
      ]
    },
    "t_andy_investigate": {
      "char": "char_andy",
      "title": "请Andy调查",
      "dialogue": [
        {
          "s": "npc",
          "speaker": "char_andy",
          "t": "有需要帮忙的吗？跟乐园事务有关系的事情，都可以问我。",
          "present": {
            "ev_meiyu_locker": {
              "resolved": false,
              "dialogue": [
                {
                  "s": "npc",
                  "speaker": "char_andy",
                  "t": "嗯？美羽的柜子，这里有什么东西引起了你的兴趣吗？"
                },
                {
                  "s": "player",
                  "speaker": "none",
                  "t": "让我在意的物品是……",
                  "choices": {
                    "question": "让我在意的物品是？",
                    "options": [
                      {
                        "text": "A Sweet字样的猫头志愿者徽章",
                        "correct": false,
                        "reply": "这个，我也没见过哎。"
                      },
                      {
                        "text": "B 花车巡游事故报告",
                        "correct": true
                      },
                      {
                        "text": "C 舍曲林",
                        "correct": false,
                        "reply": "看来，演员们压力真的很大啊……"
                      }
                    ]
                  }
                },
                {
                  "s": "player",
                  "speaker": "none",
                  "t": "关于这个事故调查报告，你有印象吗？时间是2024年5月2日。"
                },
                {
                  "s": "npc",
                  "speaker": "char_andy",
                  "t": "有印象，当时正好是过节嘛，巡游的花车突然发出一声巨响，还冒了一大片白烟。美羽就在那节出事的车厢上，把她吓得够呛。调查结果就像这个报告上说的一样。"
                },
                {
                  "s": "npc",
                  "speaker": "char_andy",
                  "t": "当时还通报批评了呢，负责维修检查的那个同事被扣了一大笔奖金。这件事影响还是蛮大的，乐园方召集大家开了好几次会，也固定下来每年要做至少四次安全培训。",
                  "unlockEv": [
                    "ev_float_accident"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "t_meiyu_self": {
      "char": "char_meiyu",
      "title": "请介绍一下你自己",
      "dialogue": [
        {
          "s": "npc",
          "speaker": "char_meiyu",
          "t": "我是美羽，乐园的舞蹈演员，一般是白班的工作，晚班的话，我是鬼屋项目的临时演员，如果有需要我也会上场。"
        },
        {
          "s": "npc",
          "speaker": "char_meiyu",
          "t": "我在乐园工作四年了。",
          "question": {
            "resolved": false,
            "dialogue": [
              {
                "s": "player",
                "speaker": "none",
                "t": "鬼屋立项时，你知道当时鬼屋组演员的情况吗？"
              },
              {
                "s": "npc",
                "speaker": "char_meiyu",
                "t": "知道，一开始是明淇牵头，写了企划提交上去，然后上边就交给常威去落地。"
              },
              {
                "s": "npc",
                "speaker": "char_meiyu",
                "t": "真橙跟常威关系比较好，所以很早就加入这个项目，肖桦是跟着真橙过去的。",
                "question": {
                  "resolved": false,
                  "dialogue": [
                    {
                      "s": "player",
                      "speaker": "none",
                      "t": "所以你也认识肖桦，是吗？"
                    },
                    {
                      "s": "npc",
                      "speaker": "char_meiyu",
                      "t": "嗯，认识的……"
                    },
                    {
                      "s": "player",
                      "speaker": "none",
                      "t": "你们关系如何？"
                    },
                    {
                      "s": "npc",
                      "speaker": "char_meiyu",
                      "t": "一般吧……"
                    },
                    {
                      "s": "player",
                      "speaker": "none",
                      "t": "那你知道他有没有家人、朋友、恋人之类的？"
                    },
                    {
                      "s": "npc",
                      "speaker": "char_meiyu",
                      "t": "那就不知道了。"
                    },
                    {
                      "s": "npc",
                      "speaker": "char_meiyu",
                      "t": "阿祐是后来才来的，刚开始算是场务和道具师？类似这样的角色？然后就当了演员。"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    },
